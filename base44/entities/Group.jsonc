{
  "name": "Group",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Group name"
    },
    "ownerId": {
      "type": "string",
      "description": "User ID of the group owner"
    },
    "memberIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of member User IDs",
      "default": []
    },
    "isPrivate": {
      "type": "boolean",
      "default": true,
      "description": "Whether the group is private"
    },
    "joinCode": {
      "type": "string",
      "description": "Short 6-character code for joining the group"
    },
    "communityGoal": {
      "type": "string",
      "description": "Description of the community goal (e.g. Read 1,000 chapters together this month)"
    },
    "communityGoalTarget": {
      "type": "number",
      "description": "Target chapter count for the community goal"
    },
    "communityGoalBadgeAwarded": {
      "type": "boolean",
      "default": false,
      "description": "Whether the goal badge has been awarded"
    },
    "avatarUrl": {
      "type": "string",
      "description": "URL of the group's profile picture"
    }
  },
  "required": [
    "name",
    "ownerId"
  ],
  "rls": {
    "create": true,
    "update": true,
    "delete": {
      "data.ownerId": "{{user.id}}"
    },
    "read": true
  }
}