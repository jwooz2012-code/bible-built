{
  "name": "UserWallet",
  "type": "object",
  "properties": {
    "userId": {
      "type": "string",
      "description": "User ID \u2014 one wallet per user"
    },
    "xpBalance": {
      "type": "number",
      "default": 0,
      "description": "Unified XP balance \u2014 used for both leveling and purchasing artifacts"
    },
    "level": {
      "type": "number",
      "default": 1,
      "description": "Cached level = floor(xpBalance / 1000) + 1"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of last wallet update"
    }
  },
  "required": [
    "userId"
  ],
  "rls": {
    "create": false,
    "update": true,
    "delete": true,
    "read": true
  }
}