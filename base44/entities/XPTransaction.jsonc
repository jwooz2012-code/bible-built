{
  "name": "XPTransaction",
  "type": "object",
  "properties": {
    "userId": {
      "type": "string",
      "description": "User ID"
    },
    "type": {
      "type": "string",
      "enum": [
        "earn_xp",
        "earn_xp_bonus",
        "spend_xp",
        "adjustment"
      ],
      "description": "Transaction type: earn_xp = base chapter XP, earn_xp_bonus = daily 30-verse bonus, spend_xp = artifact purchase"
    },
    "source": {
      "type": "string",
      "description": "Source of the transaction (chapter_read, daily_bonus, streak_7, streak_30, book_complete, artifact_purchase, backfill, etc.)"
    },
    "amount": {
      "type": "number",
      "description": "XP amount (positive = earn, negative = spend)"
    },
    "idempotencyKey": {
      "type": "string",
      "description": "Unique key to prevent duplicate grants \u2014 required for all earn/spend operations"
    },
    "metadataJson": {
      "type": "string",
      "description": "JSON string of additional metadata (chapterId, artifactSlug, etc.)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of transaction creation"
    }
  },
  "required": [
    "userId",
    "type",
    "source",
    "amount",
    "idempotencyKey",
    "createdAt"
  ],
  "rls": {
    "create": false,
    "update": false,
    "delete": false,
    "read": {
      "data.userId": "{{user.id}}"
    }
  }
}